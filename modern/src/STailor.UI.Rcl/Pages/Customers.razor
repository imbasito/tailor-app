    private void AddMeasurementRow()
    {
        _measurementDraftRows.Add(new MeasurementDraftRow(Guid.NewGuid(), string.Empty, string.Empty));
    }

    private void RemoveMeasurementRow(Guid rowId)
    {
        _measurementDraftRows.RemoveAll(row => row.Id == rowId);

        if (_measurementDraftRows.Count == 0)
        {
            _measurementDraftRows.Add(new MeasurementDraftRow(Guid.NewGuid(), string.Empty, string.Empty));
        }
    }

    private void UpdateMeasurementName(Guid rowId, string? value)
    {
        var index = _measurementDraftRows.FindIndex(row => row.Id == rowId);
        if (index < 0)
        {
            return;
        }

        _measurementDraftRows[index] = _measurementDraftRows[index] with { Name = value ?? string.Empty };
    }

    private void UpdateMeasurementValue(Guid rowId, string? value)
    {
        var index = _measurementDraftRows.FindIndex(row => row.Id == rowId);
        if (index < 0)
        {
            return;
        }

        _measurementDraftRows[index] = _measurementDraftRows[index] with { ValueText = value ?? string.Empty };
    }

    private async Task SaveMeasurementsAsync()
    {
        if (_detail?.Customer is null)
        {
            return;
        }

        if (!TryBuildMeasurementPayload(out var measurements, out var validationMessage))
        {
            _feedbackMessage = validationMessage;
            _isFeedbackError = true;
            return;
        }

        _isSavingMeasurements = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        var result = await CustomerWorkspaceService.UpsertBaselineMeasurementsAsync(
            _apiBaseUrl,
            _detail.Customer.CustomerId,
            _measurementGarmentType,
            measurements);

        _isSavingMeasurements = false;

        if (!result.IsSuccess)
        {
            _feedbackMessage = result.ErrorMessage;
            _isFeedbackError = true;
            return;
        }

        _feedbackMessage = $"Baseline measurements saved for {_measurementGarmentType}.";
        _isFeedbackError = false;
        await SelectCustomerAsync(_detail.Customer.CustomerId);
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs eventArgs)
    {
        if (!string.Equals(eventArgs.Key, "Enter", StringComparison.Ordinal))
        {
            return;
        }

        await LoadCustomersAsync();
    }

    private async Task AdvanceStatusAsync(CustomerWorkspaceOrderDto order)
    {
        var nextStatus = GetNextStatus(order.Status);
        if (nextStatus is null)
        {
            return;
        }

        _activeTransitionOrderId = order.OrderId;
        _isTransitioningStatus = true;

        var result = await OrderWorklistService.TransitionStatusAsync(
            _apiBaseUrl,
            order.OrderId,
            nextStatus);

        _isTransitioningStatus = false;
        _activeTransitionOrderId = null;

        if (!result.IsSuccess)
        {
            _feedbackMessage = result.ErrorMessage;
            _isFeedbackError = true;
            return;
        }

        _feedbackMessage = $"Order advanced to {FormatStatus(nextStatus)}.";
        _isFeedbackError = false;
        await LoadCustomersAsync();
    }

    private static bool TryReadMeasurements(string json, out IReadOnlyList<KeyValuePair<string, decimal>> measurements)
    {
        try
        {
            var parsed = JsonSerializer.Deserialize<Dictionary<string, decimal>>(json) ?? [];
            measurements = parsed
                .OrderBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase)
                .ToArray();
            return true;
        }
        catch (JsonException)
        {
            measurements = [];
            return false;
        }
    }

    private void InitializeMeasurementEditor(string? baselineMeasurementsJson, bool preferSavedWhenCurrentMissing = false)
    {
        var groups = ParseMeasurementGroups(baselineMeasurementsJson);
        if (string.IsNullOrWhiteSpace(_measurementGarmentType))
        {
            _measurementGarmentType = GetDefaultMeasurementGarment();
        }

        if (preferSavedWhenCurrentMissing && groups.Count > 0 && !groups.ContainsKey(_measurementGarmentType))
        {
            _measurementGarmentType = groups.Keys
                .OrderBy(GetGarmentSortKey, StringComparer.OrdinalIgnoreCase)
                .First();
        }

        if (!groups.TryGetValue(_measurementGarmentType, out var selectedMeasurements) || selectedMeasurements.Count == 0)
        {
            _measurementDraftRows =
            [
                new MeasurementDraftRow(Guid.NewGuid(), string.Empty, string.Empty),
            ];
            return;
        }

        _measurementDraftRows = selectedMeasurements
            .OrderBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase)
            .Select(pair => new MeasurementDraftRow(Guid.NewGuid(), pair.Key, FormatMeasurementValue(pair.Value)))
            .ToList();
    }

    private void ResetMeasurementEditor()
    {
        _measurementGarmentType = GetDefaultMeasurementGarment();
        _measurementDraftRows =
        [
            new MeasurementDraftRow(Guid.NewGuid(), string.Empty, string.Empty),
        ];
    }

    private IReadOnlyList<string> GetMeasurementGarmentOptions()
    {
        var options = new HashSet<string>(GetConfiguredGarmentTypes(), StringComparer.OrdinalIgnoreCase);
        foreach (var garmentType in GetSavedMeasurementSets(_detail?.Customer?.BaselineMeasurementsJson))
        {
            options.Add(garmentType);
        }

        return options
            .OrderBy(GetGarmentSortKey, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private string GetDefaultMeasurementGarment()
    {
        return GetConfiguredGarmentTypes()[0];
    }

    private IReadOnlyList<string> GetConfiguredGarmentTypes()
    {
        return WorkspaceSettings.GarmentTypes.Count == 0
            ? WorkspaceSettingsService.DefaultGarmentTypes
            : WorkspaceSettings.GarmentTypes;
    }

    private IReadOnlyList<string> GetSavedMeasurementSets(string? baselineMeasurementsJson)
    {
        return ParseMeasurementGroups(baselineMeasurementsJson)
            .Keys
            .OrderBy(GetGarmentSortKey, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static int GetSavedMeasurementSetCount(string? baselineMeasurementsJson)
    {
        return ParseMeasurementGroups(baselineMeasurementsJson).Count;
    }

    private static Dictionary<string, Dictionary<string, decimal>> ParseMeasurementGroups(string? baselineMeasurementsJson)
    {
        if (string.IsNullOrWhiteSpace(baselineMeasurementsJson))
        {
            return new Dictionary<string, Dictionary<string, decimal>>(StringComparer.OrdinalIgnoreCase);
        }

        try
        {
            var parsed = JsonSerializer.Deserialize<Dictionary<string, decimal>>(baselineMeasurementsJson) ?? [];
            var grouped = new Dictionary<string, Dictionary<string, decimal>>(StringComparer.OrdinalIgnoreCase);

            foreach (var pair in parsed)
            {
                var separatorIndex = pair.Key.IndexOf(':');
                var garmentType = separatorIndex > 0 ? pair.Key[..separatorIndex].Trim() : "General";
                var measurementName = separatorIndex > 0 ? pair.Key[(separatorIndex + 1)..].Trim() : pair.Key.Trim();

                if (string.IsNullOrWhiteSpace(measurementName))
                {
                    continue;
                }

                if (!grouped.TryGetValue(garmentType, out var measurements))
                {
                    measurements = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
                    grouped[garmentType] = measurements;
                }

                measurements[measurementName] = pair.Value;
            }

            return grouped;
        }
        catch (JsonException)
        {
            return new Dictionary<string, Dictionary<string, decimal>>(StringComparer.OrdinalIgnoreCase);
        }
    }

    private bool TryBuildMeasurementPayload(
        out IReadOnlyDictionary<string, decimal> measurements,
        out string validationMessage)
    {
        var payload = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

        foreach (var row in _measurementDraftRows)
        {
            var name = row.Name.Trim();
            var hasName = !string.IsNullOrWhiteSpace(name);
            var valueText = row.ValueText.Trim();
            var hasValue = !string.IsNullOrWhiteSpace(valueText);

            if (!hasName && !hasValue)
            {
                continue;
            }

            if (!hasName)
            {
                measurements = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
                validationMessage = "Every measurement row needs a name.";
                return false;
            }

            if (!hasValue || !TryParseMeasurementValue(valueText, out var numericValue) || numericValue <= 0m)
            {
                measurements = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
                validationMessage = "Measurement values must be valid numbers like 40, 3/2, or 1-3/2.";
                return false;
            }

            if (!payload.TryAdd(name, numericValue))
            {
                measurements = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
                validationMessage = $"Duplicate measurement name '{name}' is not allowed.";
                return false;
            }
        }

        if (payload.Count == 0)
        {
            measurements = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
            validationMessage = "Add at least one measurement before saving.";
            return false;
        }

        measurements = payload;
        validationMessage = string.Empty;
        return true;
    }

