    private string BuildOrderPrefillLink(CustomerWorkspaceDetailDto customer)
    {
        var queryParts = new List<string>
        {
            $"customerId={Uri.EscapeDataString(customer.CustomerId.ToString())}",
            $"fullName={Uri.EscapeDataString(customer.FullName)}",
            $"phoneNumber={Uri.EscapeDataString(customer.PhoneNumber)}",
            $"city={Uri.EscapeDataString(customer.City)}",
        };

        if (!string.IsNullOrWhiteSpace(customer.Notes))
        {
            queryParts.Add($"notes={Uri.EscapeDataString(customer.Notes)}");
        }

        return $"/orders/new?{string.Join("&", queryParts)}";
    }

