    private static bool TryParseMeasurementValue(string valueText, out decimal value)
    {
        value = 0m;

        if (string.IsNullOrWhiteSpace(valueText))
        {
            return false;
        }

        var normalized = valueText.Trim();
        if (decimal.TryParse(normalized, NumberStyles.Number, CultureInfo.InvariantCulture, out value))
        {
            return true;
        }

        if (decimal.TryParse(normalized, NumberStyles.Number, CultureInfo.CurrentCulture, out value))
        {
            return true;
        }

        var mixedSeparatorIndex = normalized.IndexOf('-');
        if (mixedSeparatorIndex > 0)
        {
            var wholePart = normalized[..mixedSeparatorIndex].Trim();
            var fractionPart = normalized[(mixedSeparatorIndex + 1)..].Trim();
            if (decimal.TryParse(wholePart, NumberStyles.Integer, CultureInfo.InvariantCulture, out var wholeValue)
                && TryParseFraction(fractionPart, out var fractionValue))
            {
                value = wholeValue + fractionValue;
                return true;
            }
        }

        var spaceSeparatorIndex = normalized.IndexOf(' ');
        if (spaceSeparatorIndex > 0)
        {
            var wholePart = normalized[..spaceSeparatorIndex].Trim();
            var fractionPart = normalized[(spaceSeparatorIndex + 1)..].Trim();
            if (decimal.TryParse(wholePart, NumberStyles.Integer, CultureInfo.InvariantCulture, out var wholeValue)
                && TryParseFraction(fractionPart, out var fractionValue))
            {
                value = wholeValue + fractionValue;
                return true;
            }
        }

        return TryParseFraction(normalized, out value);
    }

    private static bool TryParseFraction(string valueText, out decimal value)
    {
        value = 0m;
        var parts = valueText.Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length != 2)
        {
            return false;
        }

        if (!decimal.TryParse(parts[0], NumberStyles.Number, CultureInfo.InvariantCulture, out var numerator)
            || !decimal.TryParse(parts[1], NumberStyles.Number, CultureInfo.InvariantCulture, out var denominator)
            || denominator == 0m)
        {
            return false;
        }

        value = numerator / denominator;
        return true;
    }

    private string GetGarmentSortKey(string garmentType)
    {
        var defaultIndex = GetConfiguredGarmentTypes()
            .Select((option, index) => new { option, index })
            .FirstOrDefault(item => string.Equals(item.option, garmentType, StringComparison.OrdinalIgnoreCase))
            ?.index ?? -1;

        return defaultIndex >= 0
            ? defaultIndex.ToString("D3", System.Globalization.CultureInfo.InvariantCulture)
            : $"999-{garmentType}";
    }

    private static string FormatStatus(string status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Unknown";
        }

        return string.Concat(status.Select((character, index) =>
            index > 0 && char.IsUpper(character) ? $" {character}" : character.ToString()));
    }

    private static string? GetNextStatus(string status)
    {
        return status switch
        {
            "New" => "InProgress",
            "InProgress" => "TrialFitting",
            "TrialFitting" => "Rework",
            "Rework" => "Ready",
            "Ready" => "Delivered",
            _ => null,
        };
    }

