    private void ArmPayment(CustomerWorkspaceOrderDto order)
    {
        _activePaymentOrderId = order.OrderId;
        _paymentAmount = order.BalanceDue > 0m ? order.BalanceDue : null;
        _paymentNote = null;
        _feedbackMessage = null;
        _isFeedbackError = false;
    }

    private void CancelPayment()
    {
        _activePaymentOrderId = null;
        _paymentAmount = null;
        _paymentNote = null;
    }

    private async Task OpenCustomerHistoryAsync()
    {
        if (_detail?.Customer is null)
        {
            return;
        }

        _isHistoryModalOpen = true;
        _isLoadingHistory = true;
        _historyError = null;
        _historyItems = [];

        var historyItems = new List<CustomerHistoryItem>();
        foreach (var order in _detail.Customer.RecentOrders)
        {
            var detailResult = await OrderWorklistService.GetDetailAsync(_apiBaseUrl, order.OrderId);
            if (!detailResult.IsSuccess || detailResult.Order is null)
            {
                historyItems.Add(new CustomerHistoryItem(
                    order.ReceivedAtUtc,
                    "Order",
                    $"{order.GarmentType} order received",
                    $"Status {FormatStatus(order.Status)}. Due {FormatDate(order.DueAtUtc)}. Balance {FormatMoney(order.BalanceDue)}."));
                continue;
            }

            AddOrderHistory(historyItems, detailResult.Order);
        }

        if (historyItems.Count == 0)
        {
            historyItems.Add(new CustomerHistoryItem(
                _detail.Customer.UpdatedAtUtc,
                "Profile",
                "Customer profile updated",
                "No orders are recorded for this customer yet."));
        }

        _historyItems = historyItems
            .OrderByDescending(item => item.OccurredAtUtc)
            .ToList();
        _isLoadingHistory = false;
    }

    private void CloseCustomerHistory()
    {
        _isHistoryModalOpen = false;
        _isLoadingHistory = false;
        _historyError = null;
        _historyItems = [];
    }

    private static void AddOrderHistory(List<CustomerHistoryItem> historyItems, OrderWorkspaceDetailDto order)
    {
        historyItems.Add(new CustomerHistoryItem(
            order.ReceivedAtUtc,
            "Order",
            $"{order.GarmentType} order received",
            $"Status {FormatStatus(order.Status)}. Due {FormatDate(order.DueAtUtc)}. Balance {FormatMoney(order.BalanceDue)}."));

        if (order.TrialScheduledAtUtc is not null)
        {
            historyItems.Add(new CustomerHistoryItem(
                order.TrialScheduledAtUtc.Value,
                "Fitting",
                $"{order.GarmentType} fitting scheduled",
                string.IsNullOrWhiteSpace(order.TrialScheduleStatus)
                    ? "Customer fitting date was saved for this order."
                    : $"Fitting status: {order.TrialScheduleStatus}."));
        }

        foreach (var payment in order.Payments)
        {
            historyItems.Add(new CustomerHistoryItem(
                payment.PaidAtUtc,
                "Payment",
                "Payment collected",
                string.IsNullOrWhiteSpace(payment.Note)
                    ? $"{order.GarmentType} order. Total {FormatMoney(order.AmountCharged)}. Paid {FormatMoney(order.AmountPaid)}. Balance {FormatMoney(order.BalanceDue)}."
                    : $"{order.GarmentType} order. Total {FormatMoney(order.AmountCharged)}. Paid {FormatMoney(order.AmountPaid)}. Balance {FormatMoney(order.BalanceDue)}. Note: {payment.Note}",
                FormatMoney(payment.Amount)));
        }
    }

    private async Task SubmitPaymentAsync(CustomerWorkspaceOrderDto order)
    {
        if (_paymentAmount is null || _paymentAmount <= 0m)
        {
            _feedbackMessage = "Payment amount must be greater than zero.";
            _isFeedbackError = true;
            return;
        }

        if (_paymentAmount > order.BalanceDue)
        {
            _feedbackMessage = "Payment cannot exceed the current balance due.";
            _isFeedbackError = true;
            return;
        }

        _isSubmittingPayment = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        var result = await OrderWorklistService.AddPaymentAsync(
            _apiBaseUrl,
            order.OrderId,
            _paymentAmount.Value,
            _paymentNote);
        _isSubmittingPayment = false;

        if (!result.IsSuccess)
        {
            _feedbackMessage = result.ErrorMessage;
            _isFeedbackError = true;
            return;
        }

        _feedbackMessage = "Payment recorded successfully.";
        _isFeedbackError = false;
        CancelPayment();
        await LoadCustomersAsync();
    }

