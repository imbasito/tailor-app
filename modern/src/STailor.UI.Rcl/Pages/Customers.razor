@page "/customers"
@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using STailor.Shared.Contracts.Customers
@using STailor.Shared.Contracts.Measurements
@using STailor.Shared.Contracts.Orders
@using STailor.UI.Rcl.Services
@inject CustomerWorkspaceService CustomerWorkspaceService
@inject OrderWorklistService OrderWorklistService
@inject WorkspaceSettingsService WorkspaceSettings
@inject IJSRuntime JsRuntime

<section class="customers-shell">
    <header class="customers-header">
        <div class="header-copy">
            <p class="eyebrow">Customer Operations</p>
            <h1>Customer History</h1>
            <p>Find returning customers, review saved measurements, check recent orders, and safely remove inactive records.</p>
        </div>
        <a class="primary-link" href="/orders/new">Start New Order</a>
    </header>

    <section class="toolbar-card">
        <div class="toolbar-grid">
            <label>
                Search
                <input type="search" @bind="_searchText" @onkeydown="HandleSearchKeyDown" placeholder="Name, phone, or city" />
            </label>
            <label>
                Max Items
                <input type="number" min="1" max="100" @bind="_maxItems" @onkeydown="HandleSearchKeyDown" />
            </label>
        </div>

        <div class="toolbar-actions">
            <button type="button" @onclick="LoadCustomersAsync" disabled="@_isLoadingList">Load Customers</button>
            <button type="button" class="ghost" @onclick="ClearSearch" disabled="@_isLoadingList">Reset Search</button>
        </div>

        <div class="customer-filter-row" aria-label="Customer quick filters">
            <span>Quick filters</span>
            <button type="button" class="@GetCustomerQuickFilterClass(CustomerQuickFilter.Balance)" @onclick="() => SetCustomerQuickFilter(CustomerQuickFilter.Balance)">Balance</button>
            <button type="button" class="@GetCustomerQuickFilterClass(CustomerQuickFilter.Recent)" @onclick="() => SetCustomerQuickFilter(CustomerQuickFilter.Recent)">Recent</button>
            <button type="button" class="@GetCustomerQuickFilterClass(CustomerQuickFilter.NoOrders)" @onclick="() => SetCustomerQuickFilter(CustomerQuickFilter.NoOrders)">No Orders</button>
            <button type="button" class="@GetCustomerQuickFilterClass(CustomerQuickFilter.Frequent)" @onclick="() => SetCustomerQuickFilter(CustomerQuickFilter.Frequent)">Frequent Customers</button>
            <button type="button" class="@GetCustomerQuickFilterClass(CustomerQuickFilter.All)" @onclick="() => SetCustomerQuickFilter(CustomerQuickFilter.All)">All</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_feedbackMessage))
        {
            <p class="@GetFeedbackClass()">@_feedbackMessage</p>
        }
    </section>

    <div class="workspace-grid">
        <section class="list-card">
            <header class="section-header">
                <h2>Customers</h2>
                <div class="section-header-actions">
                    <span>@GetVisibleCustomers().Count loaded</span>
                    <button
                        type="button"
                        class="ghost compact-action"
                        @onclick="ToggleCustomerDensity">
                        @(_useCompactCustomerCards ? "Comfortable" : "Compact")
                    </button>
                </div>
            </header>

            @if (_isLoadingList)
            {
                <p>Loading customers...</p>
            }
            else if (GetVisibleCustomers().Count == 0)
            {
                <p class="muted">No customers match the current search.</p>
            }
            else
            {
                <div class="@GetCustomerListClass()">
                    @foreach (var customer in GetVisibleCustomers())
                    {
                        var isSelected = _selectedCustomerId == customer.CustomerId;
                        <button
                            type="button"
                            class="@GetCustomerCardClass(isSelected)"
                            @onclick="() => SelectCustomerAsync(customer.CustomerId)">
                            <div class="customer-card-topline">
                                <div class="customer-identity">
                                    <strong>@customer.FullName</strong>
                                    <span>@customer.City</span>
                                </div>
                                <span class="@GetBalanceChipClass(customer.OutstandingBalance)">
                                    @(customer.OutstandingBalance > 0m ? $"Due {FormatMoney(customer.OutstandingBalance)}" : "Paid")
                                </span>
                            </div>
                            <div class="customer-card-meta">
                                <span>@customer.PhoneNumber</span>
                                <span>@customer.OrderCount order(s)</span>
                                <span>@FormatLastOrder(customer.LastOrderReceivedAtUtc)</span>
                            </div>
                            @if (!_useCompactCustomerCards && !string.IsNullOrWhiteSpace(customer.Notes))
                            {
                                <p class="customer-note">@customer.Notes</p>
                            }
                        </button>
                    }
                </div>
            }
        </section>

        <section class="detail-card">
            <header class="section-header">
                <div class="detail-header-title">
                    <h2>Customer Detail</h2>
                    @if (_detail?.Customer is not null)
                    {
                        <div class="detail-header-chips">
                            <span class="@GetBalanceChipClass(_detail.Customer.OutstandingBalance)">Balance Due @FormatMoney(_detail.Customer.OutstandingBalance)</span>
                            <span>@GetLastOrderStatusText(_detail.Customer)</span>
                        </div>
                    }
                </div>
                @if (_detail?.Customer is not null)
                {
                    <div class="section-header-actions">
                        <span>Updated @_detail.Customer.UpdatedAtUtc.ToString("yyyy-MM-dd")</span>
                        <button
                            type="button"
                            class="ghost compact-action"
                            @onclick="OpenCustomerEdit">
                            Edit
                        </button>
                        <button
                            type="button"
                            class="ghost compact-action"
                            @onclick="OpenCustomerHistoryAsync"
                            disabled="@_isLoadingHistory">
                            @(_isLoadingHistory ? "Loading..." : "View History")
                        </button>
                        <button
                            type="button"
                            class="ghost compact-action"
                            @onclick="PrintCustomerStatementAsync">
                            Print
                        </button>
                    </div>
                }
            </header>

            @if (_isLoadingDetail)
            {
                <p>Loading customer detail...</p>
            }
            else if (_detail?.Customer is null)
            {
                <p class="muted">Choose a customer to view saved measurements and recent orders.</p>
            }
            else
            {
                var customer = _detail.Customer;
                <div class="detail-top">
                    <div>
                        <h3>@customer.FullName</h3>
                        <p class="customer-since">Customer since @FormatDate(customer.CreatedAtUtc)</p>
                        <p>@customer.PhoneNumber</p>
                        <p>@customer.City</p>
                        @if (!string.IsNullOrWhiteSpace(customer.Notes))
                        {
                            <details class="customer-notes">
                                <summary>Notes</summary>
                                <p>@customer.Notes</p>
                            </details>
                        }
                    </div>

                    <div class="detail-stats">
                        <div>
                            <span class="stat-label">Outstanding Balance</span>
                            <strong>@customer.OutstandingBalance</strong>
                        </div>
                        <div>
                            <span class="stat-label">Recent Orders</span>
                            <strong>@customer.RecentOrders.Count</strong>
                        </div>
                    </div>
                </div>

                <div class="detail-actions">
                    <a class="secondary-link" href="@BuildOrderPrefillLink(customer)">Start New Order</a>
                    @if (_confirmDeleteCustomerId == customer.CustomerId)
                    {
                        <button type="button" class="danger" @onclick="ConfirmDeleteSelectedAsync" disabled="@_isDeleting">@(_isDeleting ? "Deleting..." : "Confirm Delete")</button>
                        <button type="button" class="ghost" @onclick="CancelDelete" disabled="@_isDeleting">Cancel</button>
                    }
                    else
                    {
                        <button type="button" class="danger" @onclick="@(() => ArmDelete(customer.CustomerId))" disabled="@_isDeleting">@(_isDeleting ? "Deleting..." : "Delete Customer")</button>
                    }
                </div>

                @if (_confirmDeleteCustomerId == customer.CustomerId)
                {
                    <p class="delete-warning">Delete is blocked automatically when orders still exist for this customer.</p>
                }

                <div class="detail-sections">
                    <section class="nested-card">
                        <h3>Saved Measurements</h3>
                        <p class="muted">
                            Keep reusable customer measurements here. Each order still keeps its own saved copy from intake.
                        </p>

                        <div class="measurement-editor-toolbar">
                            <label>
                                Garment Type
                                <select value="@_measurementGarmentType" @onchange="OnMeasurementGarmentTypeChanged">
                                    @foreach (var garmentType in GetMeasurementGarmentOptions())
                                    {
                                        <option value="@garmentType">@garmentType</option>
                                    }
                                </select>
                            </label>
                            <div class="measurement-editor-actions">
                                <button type="button" @onclick="SaveMeasurementsAsync" disabled="@_isSavingMeasurements">
                                    @(_isSavingMeasurements ? "Saving Measurements..." : "Save Measurements")
                                </button>
                            </div>
                        </div>

                        @if (GetSavedMeasurementSetCount(customer.BaselineMeasurementsJson) > 0)
                        {
                            <div class="measurement-set-list">
                                @foreach (var garmentType in GetSavedMeasurementSets(customer.BaselineMeasurementsJson))
                                {
                                    <button
                                        type="button"
                                        class="measurement-set-chip @(string.Equals(garmentType, _measurementGarmentType, StringComparison.OrdinalIgnoreCase) ? "selected" : string.Empty)"
                                        @onclick="() => SelectMeasurementGarment(garmentType)">
                                        @garmentType
                                    </button>
                                }
                            </div>
                        }

                        <div class="measurement-editor-list" role="table" aria-label="Saved measurement rows">
                            <div class="measurement-editor-row measurement-editor-head" role="row">
                                <span role="columnheader">Name</span>
                                <span role="columnheader">Value</span>
                                <span role="columnheader">Action</span>
                            </div>

                            @foreach (var row in _measurementDraftRows)
                            {
                                <div class="measurement-editor-row" role="row">
                                    <input
                                        role="cell"
                                        type="text"
                                        value="@row.Name"
                                        @oninput="eventArgs => UpdateMeasurementName(row.Id, eventArgs.Value?.ToString())"
                                        placeholder="Chest, Sleeve, Waist"
                                        aria-label="Measurement name" />
                                    <input
                                        role="cell"
                                        type="text"
                                        inputmode="decimal"
                                        value="@row.ValueText"
                                        placeholder="40, 3/2, 1-3/2"
                                        @oninput="eventArgs => UpdateMeasurementValue(row.Id, eventArgs.Value?.ToString())"
                                        aria-label="Measurement value" />
                                    <button type="button" class="ghost remove-measurement-button" @onclick="() => RemoveMeasurementRow(row.Id)">
                                        Remove
                                    </button>
                                </div>
                            }
                            <button type="button" class="add-row-button" title="Add measurement" aria-label="Add measurement" @onclick="AddMeasurementRow">+</button>
                        </div>
                    </section>

                    <section class="nested-card">
                        <h3>Recent Orders</h3>
                        @if (customer.RecentOrders.Count == 0)
                        {
                            <p class="muted">No orders found for this customer yet.</p>
                        }
                        else
                        {
                            <div class="recent-orders">
                                @foreach (var order in customer.RecentOrders)
                                {
                                    <article class="order-card">
                                        <div class="order-card-header">
                                            <strong>@order.GarmentType</strong>
                                            <span>@FormatStatus(order.Status)</span>
                                        </div>
                                        <div class="order-card-meta">
                                            <span>Received @order.ReceivedAtUtc.ToString("yyyy-MM-dd")</span>
                                            <span>Due @order.DueAtUtc.ToString("yyyy-MM-dd")</span>
                                            <span>Balance @order.BalanceDue</span>
                                        </div>
                                        <div class="order-card-actions">
                                            <a class="secondary-link" href="@BuildOrderDetailLink(order.OrderId)">Open Order</a>
                                        </div>
                                        @if (TryReadMeasurements(order.MeasurementSnapshotJson, out var snapshotMeasurements) && snapshotMeasurements.Count > 0)
                                        {
                                        <details>
                                                <summary>Measurements saved with this order</summary>
                                                <dl class="measurement-list compact">
                                                    @foreach (var measurement in snapshotMeasurements)
                                                    {
                                                        <div>
                                                            <dt>@measurement.Key</dt>
                                                            <dd>@measurement.Value</dd>
                                                        </div>
                                                    }
                                                </dl>
                                            </details>
                                        }
                                        @{
                                            var nextStatus = GetNextStatus(order.Status);
                                        }
                                        @if (nextStatus is not null)
                                        {
                                            <div class="order-card-actions status-card-actions">
                                                <button
                                                    type="button"
                                                    class="ghost status-action-button"
                                                    @onclick="@(() => AdvanceStatusAsync(order))"
                                                    disabled="@_isTransitioningStatus">
                                                    @(_isTransitioningStatus && _activeTransitionOrderId == order.OrderId
                                                        ? "Advancing..."
                                                        : $"Advance to {FormatStatus(nextStatus)}")
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="muted order-complete">Lifecycle complete.</p>
                                        }
                                        @if (order.BalanceDue > 0m)
                                        {
                                            <div class="order-card-actions">
                                                @if (_activePaymentOrderId == order.OrderId)
                                                {
                                                    <div class="payment-panel">
                                                        <label>
                                                            Payment Amount
                                                            <input type="number" min="0.01" max="@order.BalanceDue" step="0.01" @bind="_paymentAmount" />
                                                        </label>
                                                        <label>
                                                            Note (Optional)
                                                            <input type="text" @bind="_paymentNote" placeholder="Cash, transfer, reminder visit" />
                                                        </label>
                                                        <div class="payment-actions">
                                                            <button type="button" @onclick="@(() => SubmitPaymentAsync(order))" disabled="@_isSubmittingPayment">
                                                                @(_isSubmittingPayment ? "Saving Payment..." : "Save Payment")
                                                            </button>
                                                            <button type="button" class="ghost" @onclick="CancelPayment" disabled="@_isSubmittingPayment">Cancel</button>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <button type="button" class="ghost" @onclick="@(() => ArmPayment(order))">Collect Payment</button>
                                                }
                                            </div>
                                        }
                                    </article>
                                }
                            </div>
                        }
                    </section>
                </div>
            }
        </section>
    </div>
</section>

@if (_detail?.Customer is not null)
{
    var statementCustomer = _detail.Customer;
    <section class="customer-statement-print" aria-label="Printed customer statement">
        <header class="statement-header">
            @if (!string.IsNullOrWhiteSpace(WorkspaceSettings.LogoDataUrl))
            {
                <img src="@WorkspaceSettings.LogoDataUrl" alt="@WorkspaceSettings.ProductName logo" />
            }
            <div>
                <h1>@WorkspaceSettings.ProductName</h1>
                @if (!string.IsNullOrWhiteSpace(WorkspaceSettings.ShopAddress))
                {
                    <p>@WorkspaceSettings.ShopAddress</p>
                }
                <p>
                    @if (!string.IsNullOrWhiteSpace(WorkspaceSettings.ShopPhoneNumber))
                    {
                        <span>Phone: @WorkspaceSettings.ShopPhoneNumber</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(WorkspaceSettings.NationalTaxNumber))
                    {
                        <span>NTN: @WorkspaceSettings.NationalTaxNumber</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(WorkspaceSettings.SalesTaxRegistrationNumber))
                    {
                        <span>STRN: @WorkspaceSettings.SalesTaxRegistrationNumber</span>
                    }
                </p>
            </div>
            <div class="statement-meta">
                <strong>Customer Statement</strong>
                <span>Date: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</span>
            </div>
        </header>

        <section class="statement-cards">
            <article><span>Customer</span><strong>@statementCustomer.FullName</strong></article>
            <article><span>Phone</span><strong>@statementCustomer.PhoneNumber</strong></article>
            <article><span>Customer Since</span><strong>@FormatDate(statementCustomer.CreatedAtUtc)</strong></article>
            <article><span>Balance Due</span><strong>@FormatMoney(statementCustomer.OutstandingBalance)</strong></article>
        </section>

        <table class="statement-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Order</th>
                    <th>Garment</th>
                    <th>Status</th>
                    <th>Received</th>
                    <th>Due</th>
                    <th>Charged</th>
                    <th>Paid</th>
                    <th>Balance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in statementCustomer.RecentOrders.Select((order, index) => new { order, index }))
                {
                    <tr>
                        <td>@(row.index + 1)</td>
                        <td>@FormatOrderToken(row.order.OrderId)</td>
                        <td>@row.order.GarmentType</td>
                        <td>@FormatStatus(row.order.Status)</td>
                        <td>@FormatDate(row.order.ReceivedAtUtc)</td>
                        <td>@FormatDate(row.order.DueAtUtc)</td>
                        <td>@FormatMoney(row.order.AmountCharged)</td>
                        <td>@FormatMoney(row.order.AmountPaid)</td>
                        <td>@FormatMoney(row.order.BalanceDue)</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

@if (_isEditModalOpen && _detail?.Customer is not null)
{
    <div class="history-modal-backdrop" role="presentation" @onclick="CloseCustomerEdit">
        <section class="history-modal customer-edit-modal" role="dialog" aria-modal="true" aria-labelledby="customer-edit-title" @onclick:stopPropagation="true">
            <header class="history-modal-header">
                <div>
                    <p class="eyebrow">Edit Customer</p>
                    <h2 id="customer-edit-title">@_detail.Customer.FullName</h2>
                    <p>Update the customer's contact information without changing saved measurements or order history.</p>
                </div>
                <button type="button" class="ghost compact-action" @onclick="CloseCustomerEdit" disabled="@_isSavingCustomerEdit">Close</button>
            </header>

            <div class="customer-edit-form">
                <label>
                    Name
                    <input type="text" @bind="_editFullName" placeholder="Customer full name" />
                </label>
                <label>
                    Phone
                    <input type="tel" @bind="_editPhoneNumber" placeholder="+923001234567" />
                </label>
                <label>
                    City
                    <input type="text" @bind="_editCity" placeholder="City" />
                </label>
                <label>
                    Notes
                    <textarea @bind="_editNotes" placeholder="Optional customer notes"></textarea>
                </label>
            </div>

            @if (!string.IsNullOrWhiteSpace(_editError))
            {
                <p class="feedback error">@_editError</p>
            }

            <div class="modal-actions">
                <button type="button" @onclick="SaveCustomerEditAsync" disabled="@_isSavingCustomerEdit">
                    @(_isSavingCustomerEdit ? "Saving..." : "Save Customer")
                </button>
                <button type="button" class="ghost" @onclick="CloseCustomerEdit" disabled="@_isSavingCustomerEdit">Cancel</button>
            </div>
        </section>
    </div>
}

@if (_isHistoryModalOpen && _detail?.Customer is not null)
{
    <div class="history-modal-backdrop" role="presentation" @onclick="CloseCustomerHistory">
        <section class="history-modal" role="dialog" aria-modal="true" aria-labelledby="customer-history-title" @onclick:stopPropagation="true">
            <header class="history-modal-header">
                <div>
                    <p class="eyebrow">Customer Timeline</p>
                    <h2 id="customer-history-title">@_detail.Customer.FullName</h2>
                    <p>Orders, payments, and fitting dates in one clean history.</p>
                </div>
                <button type="button" class="ghost compact-action" @onclick="CloseCustomerHistory">Close</button>
            </header>

            @if (_isLoadingHistory)
            {
                <p class="muted">Loading customer history...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_historyError))
            {
                <p class="feedback error">@_historyError</p>
            }
            else if (_historyItems.Count == 0)
            {
                <p class="muted">No order or payment history is available yet.</p>
            }
            else
            {
                <div class="history-timeline">
                    @foreach (var item in _historyItems)
                    {
                        <article class="history-item">
                            <time datetime="@item.OccurredAtUtc.ToString("O")">@FormatHistoryDateTime(item.OccurredAtUtc)</time>
                            <div>
                                <span class="history-kind">@item.Kind</span>
                                <h3>@item.Title</h3>
                                <p>@item.Detail</p>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Amount))
                            {
                                <strong class="history-amount">@item.Amount</strong>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "apiBaseUrl")]
    private string? PrefillApiBaseUrl { get; set; }

    [SupplyParameterFromQuery(Name = "customerId")]
    private Guid? PrefillCustomerId { get; set; }

    private string _apiBaseUrl = WorkspaceSettingsService.DefaultApiBaseUrl;
    private string _searchText = string.Empty;
    private int _maxItems = 25;
    private bool _isLoadingList;
    private bool _isLoadingDetail;
    private bool _isDeleting;
    private bool _isSubmittingPayment;
    private bool _isTransitioningStatus;
    private bool _isFeedbackError;
    private bool _isHistoryModalOpen;
    private bool _isLoadingHistory;
    private bool _isEditModalOpen;
    private bool _isSavingCustomerEdit;
    private bool _useCompactCustomerCards = true;
    private CustomerQuickFilter _customerQuickFilter = CustomerQuickFilter.All;
    private string? _feedbackMessage;
    private string? _historyError;
    private string? _editError;
    private Guid? _selectedCustomerId;
    private Guid? _confirmDeleteCustomerId;
    private Guid? _activePaymentOrderId;
    private Guid? _activeTransitionOrderId;
    private decimal? _paymentAmount;
    private string? _paymentNote;
    private string _editFullName = string.Empty;
    private string _editPhoneNumber = string.Empty;
    private string _editCity = string.Empty;
    private string? _editNotes;
    private bool _isSavingMeasurements;
    private string _measurementGarmentType = "Suit";
    private List<MeasurementDraftRow> _measurementDraftRows = [];
    private List<CustomerHistoryItem> _historyItems = [];
    private List<CustomerWorkspaceItemDto> _customers = [];
    private CustomerWorkspaceDetailResult? _detail;

    private enum CustomerQuickFilter
    {
        All,
        Balance,
        Recent,
        NoOrders,
        Frequent,
    }

    protected override async Task OnInitializedAsync()
    {
        _apiBaseUrl = WorkspaceSettings.ApiBaseUrl;

        if (!string.IsNullOrWhiteSpace(PrefillApiBaseUrl))
        {
            WorkspaceSettings.ApplyApiBaseUrlOverride(PrefillApiBaseUrl);
            _apiBaseUrl = WorkspaceSettings.ApiBaseUrl;
        }

        if (PrefillCustomerId.HasValue && PrefillCustomerId.Value != Guid.Empty)
        {
            _selectedCustomerId = PrefillCustomerId.Value;
        }

        await LoadCustomersAsync();
    }

    private async Task LoadCustomersAsync()
    {
        _isLoadingList = true;
        _feedbackMessage = null;
        _isFeedbackError = false;

        var result = await CustomerWorkspaceService.GetWorklistAsync(_apiBaseUrl, _searchText, _maxItems);
        _isLoadingList = false;

        if (!result.IsSuccess)
        {
            _customers = [];
            _detail = null;
            _selectedCustomerId = null;
            _feedbackMessage = result.ErrorMessage;
            _isFeedbackError = true;
            return;
        }

        _customers = result.Items.ToList();

        if (_selectedCustomerId.HasValue && _customers.Any(customer => customer.CustomerId == _selectedCustomerId.Value))
        {
            await SelectCustomerAsync(_selectedCustomerId.Value);
            return;
        }

        if (_customers.Count > 0)
        {
            await SelectCustomerAsync(_customers[0].CustomerId);
        }
        else
        {
            _detail = null;
            _selectedCustomerId = null;
        }
    }

    private async Task SelectCustomerAsync(Guid customerId)
    {
        _selectedCustomerId = customerId;
        _confirmDeleteCustomerId = null;
        _activePaymentOrderId = null;
        _activeTransitionOrderId = null;
        CloseCustomerHistory();
        CloseCustomerEdit();
        _isLoadingDetail = true;

        var detail = await CustomerWorkspaceService.GetDetailAsync(_apiBaseUrl, customerId, recentOrderLimit: 5);
        _isLoadingDetail = false;
        _detail = detail;

        if (!detail.IsSuccess)
        {
            _feedbackMessage = detail.ErrorMessage;
            _isFeedbackError = true;
            ResetMeasurementEditor();
            return;
        }

        InitializeMeasurementEditor(detail.Customer!.BaselineMeasurementsJson, preferSavedWhenCurrentMissing: true);
    }

    private void ArmDelete(Guid customerId)
    {
        _confirmDeleteCustomerId = customerId;
        _feedbackMessage = "Confirm delete only when you are sure this customer has no active order history to keep.";
        _isFeedbackError = false;
    }

    private void CancelDelete()
    {
        _confirmDeleteCustomerId = null;
        _feedbackMessage = null;
        _isFeedbackError = false;
    }

    private async Task ConfirmDeleteSelectedAsync()
    {
        if (_confirmDeleteCustomerId is null)
        {
            return;
        }

        _isDeleting = true;
        var result = await CustomerWorkspaceService.DeleteAsync(_apiBaseUrl, _confirmDeleteCustomerId.Value);
        _isDeleting = false;

        if (!result.IsSuccess)
        {
            _feedbackMessage = result.ErrorMessage;
            _isFeedbackError = true;
            return;
        }

        _feedbackMessage = "Customer deleted successfully.";
        _isFeedbackError = false;
        _confirmDeleteCustomerId = null;
        _detail = null;
        _selectedCustomerId = null;
        await LoadCustomersAsync();
    }

    private void ClearSearch()
    {
        _searchText = string.Empty;
        _customerQuickFilter = CustomerQuickFilter.All;
    }

    private IReadOnlyList<CustomerWorkspaceItemDto> GetVisibleCustomers()
    {
        var recentSinceUtc = DateTimeOffset.UtcNow.AddDays(-30);
        return _customers
            .Where(customer => _customerQuickFilter switch
            {
                CustomerQuickFilter.Balance => customer.OutstandingBalance > 0m,
                CustomerQuickFilter.Recent => customer.LastOrderReceivedAtUtc is not null
                    && customer.LastOrderReceivedAtUtc.Value >= recentSinceUtc,
                CustomerQuickFilter.NoOrders => customer.OrderCount == 0,
                CustomerQuickFilter.Frequent => customer.OrderCount >= 3,
                _ => true,
            })
            .ToList();
    }

    private void SetCustomerQuickFilter(CustomerQuickFilter filter)
    {
        _customerQuickFilter = filter;
    }

    private string GetCustomerQuickFilterClass(CustomerQuickFilter filter)
    {
        return _customerQuickFilter == filter
            ? "quick-filter active"
            : "quick-filter";
    }

