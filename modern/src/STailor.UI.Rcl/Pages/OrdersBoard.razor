    private void PreparePayment(Guid orderId, decimal balanceDue)
    {
        _pendingBulkAdvancePlan = null;
        _pendingRetryGroupKind = null;
        _openBulkActionsGroupKind = null;
        _pendingDeleteOrderId = null;
        _pendingPaymentOrderId = orderId;
        _paymentAmountDraft = balanceDue > 0m ? balanceDue : null;
        _paymentNoteDraft = null;
        _actionMessage = null;
    }

    private void CancelPayment()
    {
        _pendingPaymentOrderId = null;
        _paymentAmountDraft = null;
        _paymentNoteDraft = null;
    }

    private async Task SubmitPaymentAsync(Guid orderId, string customerName, decimal balanceDue)
    {
        if (_submittingPaymentOrderId is not null)
        {
            return;
        }

        if (_paymentAmountDraft is null || _paymentAmountDraft <= 0m)
        {
            _isActionSuccess = false;
            _actionMessage = "Payment amount must be greater than zero.";
            return;
        }

        if (_paymentAmountDraft > balanceDue)
        {
            _isActionSuccess = false;
            _actionMessage = "Payment cannot exceed the current balance due.";
            return;
        }

        _submittingPaymentOrderId = orderId;
        _pendingBulkAdvancePlan = null;
        _pendingRetryGroupKind = null;
        _pendingDeleteOrderId = null;
        _actionMessage = null;

        try
        {
            var result = await WorklistService.AddPaymentAsync(
                _apiBaseUrl,
                orderId,
                _paymentAmountDraft.Value,
                _paymentNoteDraft);

            if (!result.IsSuccess)
            {
                _isActionSuccess = false;
                _actionMessage = result.ErrorMessage ?? "Unable to save payment.";
                return;
            }

            _isActionSuccess = true;
            _actionMessage = $"Payment recorded for {customerName}.";
            CancelPayment();
            await LoadAsync();
        }
        finally
        {
            _submittingPaymentOrderId = null;
        }
    }

