@page "/orders"
@page "/orders/board"
@using Microsoft.AspNetCore.Components
@using STailor.Shared.Contracts.Orders
@using STailor.UI.Rcl.Services
@inject OrderWorklistService WorklistService
@inject NavigationManager NavigationManager
@inject WorkspaceSettingsService WorkspaceSettings

<section class="orders-shell">
    <header class="orders-header">
        <h1>Orders</h1>
        <p>Keep today&apos;s queue, late work, and payment follow-up in one place.</p>
    </header>

    @if (_hasLoaded)
    {
        <section class="summary-grid" aria-label="Board summary">
            <article class="summary-card">
                <h3>Orders</h3>
                <p class="summary-value">@_summary.TotalOrders</p>
                <p class="summary-meta">Overdue: @_summary.OverdueCount | Due today: @_summary.DueTodayCount</p>
                <p class="summary-meta">At risk: @_summary.AtRiskCount</p>
            </article>

            <article class="summary-card">
                <h3>Lifecycle</h3>
                <p class="summary-meta">New: @_summary.NewCount | Progress: @_summary.InProgressCount</p>
                <p class="summary-meta">Trial: @_summary.TrialFittingCount | Rework: @_summary.ReworkCount</p>
                <p class="summary-meta">Ready: @_summary.ReadyCount | Delivered: @_summary.DeliveredCount</p>
                <p class="summary-meta">Ready with balance: @_summary.ReadyWithBalanceCount</p>
            </article>

            <article class="summary-card">
                <h3>Financials</h3>
                <p class="summary-meta">Charged: @_summary.TotalCharged</p>
                <p class="summary-meta">Paid: @_summary.TotalPaid</p>
                <p class="summary-meta">Collected: @FormatPercent(_summary.CollectionRatePercent)</p>
                <p class="summary-value">Balance: @_summary.TotalBalanceDue</p>
            </article>
        </section>
    }

    <div class="filters-grid">
        <label>
            Max Items
            <input type="number" min="1" max="500" @bind="_maxItems" />
        </label>

        <label>
            Status
            <select @bind="_statusFilter">
                <option value="Any">Any</option>
                <option value="New">New</option>
                <option value="InProgress">In Progress</option>
                <option value="TrialFitting">Trial/Fitting</option>
                <option value="Rework">Rework</option>
                <option value="Ready">Ready</option>
                <option value="Delivered">Delivered</option>
            </select>
        </label>

        <label>
            Due On Or Before
            <input type="date" @bind="_dueOnOrBeforeDate" />
        </label>

        <label class="checkbox-item">
            <input type="checkbox" @bind="_includeDelivered" />
            Include delivered orders
        </label>

        <label class="checkbox-item">
            <input type="checkbox" @bind="_overdueOnly" />
            Overdue only
        </label>
    </div>

    <div class="preset-row">
        <span class="preset-label">Shortcuts</span>
        <div class="preset-buttons">
            <button type="button" class="@GetPresetButtonClass(OrdersBoardQuickPreset.TodayDue)" disabled="@_isLoading" @onclick="() => ApplyQuickPresetAsync(OrdersBoardQuickPreset.TodayDue)">Today</button>
            <button type="button" class="@GetPresetButtonClass(OrdersBoardQuickPreset.Late)" disabled="@_isLoading" @onclick="() => ApplyQuickPresetAsync(OrdersBoardQuickPreset.Late)">Late</button>
            <button type="button" class="@GetPresetButtonClass(OrdersBoardQuickPreset.DueThisWeek)" disabled="@_isLoading" @onclick="() => ApplyQuickPresetAsync(OrdersBoardQuickPreset.DueThisWeek)">Due This Week</button>
            <button type="button" class="@GetPresetButtonClass(OrdersBoardQuickPreset.Unpaid)" disabled="@_isLoading" @onclick="() => ApplyQuickPresetAsync(OrdersBoardQuickPreset.Unpaid)">Unpaid</button>
            <button type="button" class="@GetPresetButtonClass(OrdersBoardQuickPreset.Ready)" disabled="@_isLoading" @onclick="() => ApplyQuickPresetAsync(OrdersBoardQuickPreset.Ready)">Ready</button>
            <button type="button" class="@GetPresetButtonClass(OrdersBoardQuickPreset.Delivered)" disabled="@_isLoading" @onclick="() => ApplyQuickPresetAsync(OrdersBoardQuickPreset.Delivered)">Delivered</button>
            <button type="button" class="ghost-button" disabled="@_isLoading" @onclick="ResetFiltersAsync">Reset</button>
        </div>
    </div>

    <div class="actions-row">
        <button type="button" disabled="@_isLoading" @onclick="LoadAsync">
            @(_isLoading ? "Loading..." : "Refresh Orders")
        </button>
        <div class="actions-meta">
            @if (_hasLoaded)
            {
                <span class="meta">Updated: @_lastLoadedAtUtc.ToString("yyyy-MM-dd HH:mm 'UTC'")</span>
            }
            <button type="button" class="ghost-button density-toggle" @onclick="ToggleOrderDensity">
                @(_useCompactOrderCards ? "Comfortable" : "Compact")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="error-box" role="alert">@_errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(_actionMessage))
    {
        <div class="action-feedback @(_isActionSuccess ? "ok" : "error")" role="status">@_actionMessage</div>
    }

    @if (_items.Count == 0 && _hasLoaded && string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="empty-box" role="status">No orders matched your filters.</div>
    }

    @if (_groupedItems.Count > 0)
    {
        @foreach (var group in _groupedItems)
        {
            var groupBulkAdvancePlan = OrdersBoardBulkAdvancePlanner.BuildPlan(group);
            var groupBulkAdvanceStatus = GetGroupBulkAdvanceStatus(group.Kind);
            var groupRetryCandidates = BuildSafeRetryCandidates(groupBulkAdvanceStatus);
            var groupRetryCount = groupRetryCandidates.Count;

            <section class="group-section @GetGroupSectionClass(group.Kind)">
                <header class="group-header">
                    <div class="group-heading">
                        <h3>@group.Title</h3>
                        <span class="group-count">@group.Items.Count</span>
                    </div>

                    <div class="group-actions">
                        @if (groupBulkAdvancePlan.HasEligible || groupRetryCount > 0)
                        {
                            <button type="button"
                                    class="group-bulk-toggle-button"
                                    @onclick="() => ToggleBulkActions(group.Kind)">
                                @GetBulkActionsToggleText(group.Kind)
                            </button>
                        }
                        <button type="button"
                                class="group-toggle-button"
                                @onclick="() => ToggleGroup(group.Kind)">
                            @GetGroupToggleText(IsGroupCollapsed(group.Kind))
                        </button>
                    </div>
                </header>

                @if (IsBulkActionsOpen(group.Kind))
                {
                    <div class="group-bulk-actions">
                        @if (groupRetryCount > 0)
                        {
                            <a class="group-action-link" href="@BuildGroupRetryableWhatsAppLink(group, groupRetryCandidates)">Retryable Summary</a>
                        }
                        <button type="button"
                                class="group-advance-button"
                                disabled="@(_isLoading || _isBulkAdvancing || !groupBulkAdvancePlan.HasEligible)"
                                @onclick="() => PrepareGroupBulkAdvance(groupBulkAdvancePlan)">
                            @GetGroupAdvanceButtonText(groupBulkAdvancePlan)
                        </button>
                        <button type="button"
                                class="group-retry-button"
                                disabled="@(_isLoading || _isBulkAdvancing || groupRetryCount == 0)"
                                @onclick="() => PrepareGroupRetry(group.Kind)">
                            @GetRetryFailedButtonText(group.Kind, groupRetryCount)
                        </button>
                    </div>
                }

                @if (groupBulkAdvanceStatus is not null)
                {
                    var failedInlineText = BuildFailedCustomerInlineText(groupBulkAdvanceStatus, 3);
                    var retryableNowLabel = OrdersBoardBulkResultMetaBuilder.BuildRetryableNowLabel(groupRetryCount);
                    var retryableDetails = OrdersBoardRetryableDetailsBuilder.Build(groupRetryCandidates, 12);
                    var isRetryableDetailsExpanded = IsRetryableDetailsExpanded(group.Kind);

                    <div class="group-bulk-result @GetGroupBulkResultClass(groupBulkAdvanceStatus)">
                        <div class="group-bulk-result-main">
                            <span>@groupBulkAdvanceStatus.Summary.Message</span>

                            @if (!string.IsNullOrWhiteSpace(failedInlineText))
                            {
                                <span class="group-bulk-failed-meta">@failedInlineText</span>
                            }

                            @if (isRetryableDetailsExpanded && retryableDetails.HasItems)
                            {
                                <ul class="group-bulk-retryable-list">
                                    @foreach (var retryableItem in retryableDetails.Items)
                                    {
                                        <li>
                                            <strong>@retryableItem.CustomerName</strong>
                                            <span class="group-bulk-retryable-order">(@FormatOrderToken(retryableItem.OrderId))</span>
                                            <span> -> @FormatStatusLabel(retryableItem.TargetStatus)</span>
                                        </li>
                                    }
                                </ul>

                                @if (retryableDetails.IsTruncated)
                                {
                                    <p class="group-bulk-retryable-more">...and @retryableDetails.HiddenCount more retryable order(s).</p>
                                }
                            }
                        </div>

                        <div class="group-bulk-result-meta">
                            @if (groupBulkAdvanceStatus.LastFailedAtUtc is not null)
                            {
                                <span class="group-bulk-result-chip warning">Last failed: @FormatUtcTimestamp(groupBulkAdvanceStatus.LastFailedAtUtc.Value)</span>
                            }

                            <span class="group-bulk-result-chip @GetRetryableNowChipClass(groupRetryCount)">@retryableNowLabel</span>

                            @if (groupRetryCount > 3 && retryableDetails.HasItems)
                            {
                                <button type="button"
                                        class="group-bulk-result-link"
                                        @onclick="() => ToggleRetryableDetails(group.Kind)">
                                    @GetRetryableDetailsToggleText(isRetryableDetailsExpanded, groupRetryCount)
                                </button>
                            }

                            <span class="group-bulk-result-time">@FormatUtcTimestamp(groupBulkAdvanceStatus.OccurredAtUtc)</span>
                        </div>
                    </div>
                }

                @if (_pendingBulkAdvancePlan?.GroupKind == group.Kind)
                {
                    var pendingPlan = _pendingBulkAdvancePlan!;
                    var bulkPreview = OrdersBoardBulkAdvancePlanner.BuildPreview(pendingPlan, 5);
                    var targetDistribution = OrdersBoardBulkAdvancePlanner.BuildTargetDistribution(pendingPlan);

                    <div class="group-bulk-confirm" role="status">
                        <p>
                            Advance @pendingPlan.EligibleCount eligible order(s) in @group.Title?
                            This applies the next workflow step per order.
                        </p>

                        @if (targetDistribution.Count > 0)
                        {
                            <div class="group-bulk-distribution">
                                @foreach (var target in targetDistribution)
                                {
                                    <span class="group-bulk-distribution-item">
                                        @FormatStatusLabel(target.TargetStatus): @target.Count
                                    </span>
                                }
                            </div>
                        }

                        @if (bulkPreview.Items.Count > 0)
                        {
                            <ul class="group-bulk-preview-list">
                                @foreach (var previewItem in bulkPreview.Items)
                                {
                                    <li>
                                        <strong>@previewItem.CustomerName</strong>
                                        <span> -> @FormatStatusLabel(previewItem.TargetStatus)</span>
                                    </li>
                                }
                            </ul>

                            @if (bulkPreview.IsTruncated)
                            {
                                <p class="group-bulk-preview-more">...and @bulkPreview.HiddenCount more order(s).</p>
                            }
                        }

                        <div class="group-bulk-confirm-buttons">
                            <button type="button"
                                    class="group-bulk-confirm-button"
                                    disabled="@_isBulkAdvancing"
                                    @onclick="ConfirmGroupBulkAdvanceAsync">
                                @GetConfirmGroupAdvanceText(pendingPlan)
                            </button>
                            <button type="button"
                                    class="group-bulk-cancel-button"
                                    disabled="@_isBulkAdvancing"
                                    @onclick="CancelGroupBulkAdvance">
                                Cancel
                            </button>
                        </div>
                    </div>
                }

                @if (_pendingRetryGroupKind == group.Kind && groupRetryCount > 0)
                {
                    var retryPreview = OrdersBoardBulkAdvanceRetryPlanner.BuildPreview(groupRetryCandidates, 5);
                    var retryDistribution = OrdersBoardBulkAdvanceRetryPlanner.BuildTargetDistribution(groupRetryCandidates);

                    <div class="group-retry-confirm" role="status">
                        <p>
                            Retry @groupRetryCount failed order(s) in @group.Title?
                            This retries only failed transitions that still match current safe next-step rules.
                        </p>

                        @if (retryDistribution.Count > 0)
                        {
                            <div class="group-bulk-distribution">
                                @foreach (var target in retryDistribution)
                                {
                                    <span class="group-bulk-distribution-item">
                                        @FormatStatusLabel(target.TargetStatus): @target.Count
                                    </span>
                                }
                            </div>
                        }

                        @if (retryPreview.Items.Count > 0)
                        {
                            <ul class="group-bulk-preview-list">
                                @foreach (var previewItem in retryPreview.Items)
                                {
                                    <li>
                                        <strong>@previewItem.CustomerName</strong>
                                        <span> -> @FormatStatusLabel(previewItem.TargetStatus)</span>
                                    </li>
                                }
                            </ul>

                            @if (retryPreview.IsTruncated)
                            {
                                <p class="group-bulk-preview-more">...and @retryPreview.HiddenCount more order(s).</p>
                            }
                        }

                        <div class="group-bulk-confirm-buttons">
                            <button type="button"
                                    class="group-retry-confirm-button"
                                    disabled="@_isBulkAdvancing"
                                    @onclick="ConfirmGroupRetryAsync">
                                @GetConfirmGroupRetryText(group.Kind, groupRetryCount)
                            </button>
                            <button type="button"
                                    class="group-bulk-cancel-button"
                                    disabled="@_isBulkAdvancing"
                                    @onclick="CancelGroupRetry">
                                Cancel
                            </button>
                        </div>
                    </div>
                }

                @if (!IsGroupCollapsed(group.Kind))
                {
                    <div class="@GetCardsGridClass()">
                        @foreach (var item in group.Items)
                        {
                            <article class="@GetOrderCardClass()">
                                <header>
                                    <div class="card-heading">
                                        <h2>@item.CustomerName</h2>
                                        <p class="card-subtitle">@item.GarmentType</p>
                                    </div>
                                    <span class="status-pill @GetStatusClass(item.Status)">@FormatStatusLabel(item.Status)</span>
                                </header>

                                <div class="card-summary-band">
                                    <span class="summary-chip @GetDueChipClass(item)">Due @item.DueAtUtc.ToString("yyyy-MM-dd")</span>
                                    @if (item.BalanceDue > 0m)
                                    {
                                        <span class="summary-chip money">Balance @item.BalanceDue</span>
                                    }
                                    else
                                    {
                                        <span class="summary-chip settled">Paid up</span>
                                    }
                                </div>

                                <dl class="order-facts">
                                    <div>
                                        <dt>Order</dt>
                                        <dd>@FormatOrderToken(item.OrderId)</dd>
                                    </div>
                                    <div>
                                        <dt>Phone</dt>
                                        <dd>@item.PhoneNumber</dd>
                                    </div>
                                    <div>
                                        <dt>City</dt>
                                        <dd>@item.City</dd>
                                    </div>
                                    <div>
                                        <dt>Received</dt>
                                        <dd>@item.ReceivedAtUtc.ToString("yyyy-MM-dd")</dd>
                                    </div>
                                    <div>
                                        <dt>Charged</dt>
                                        <dd>@item.AmountCharged</dd>
                                    </div>
                                    <div>
                                        <dt>Paid</dt>
                                        <dd>@item.AmountPaid</dd>
                                    </div>
                                </dl>

                                <div class="status-action-panel">
                                    @if (TryGetNextStatus(item.Status, out var nextStatus))
                                    {
                                        <span class="status-action-copy">Next step</span>
                                        <button type="button"
                                                class="status-primary-button"
                                                disabled="@(_isLoading || _transitioningOrderId == item.OrderId || _deletingOrderId == item.OrderId || _submittingPaymentOrderId == item.OrderId)"
                                                @onclick="() => AdvanceStatusAsync(item.OrderId, nextStatus!)">
                                            @GetAdvanceButtonText(item.OrderId, nextStatus!)
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="complete-pill">Lifecycle complete</span>
                                    }
                                </div>

                                <div class="card-actions">
                                    <div class="card-action-group secondary-actions">
                                        <a class="action-link neutral" href="@BuildOrderDetailLink(item.OrderId)">Open Order</a>
                                        <a class="action-link neutral" href="@BuildCustomerWorkspaceLink(item.CustomerId)">Open Customer</a>
                                    </div>

                                    @if (item.BalanceDue > 0m)
                                    {
                                        <div class="card-action-group money-actions">
                                            <button type="button"
                                                    class="payment-button"
                                                    disabled="@(_isLoading || _transitioningOrderId == item.OrderId || _deletingOrderId == item.OrderId || _submittingPaymentOrderId == item.OrderId)"
                                                @onclick="() => PreparePayment(item.OrderId, item.BalanceDue)">
                                                @GetPaymentButtonText(item.OrderId)
                                            </button>
                                        </div>
                                    }

                                    <div class="card-action-group whatsapp-actions">
                                        <a class="action-link" href="@BuildWhatsAppLink(item, useDueBalanceTemplate: false)"><span class="whatsapp-glyph" aria-hidden="true"></span>Status Update</a>
                                        <a class="action-link" href="@BuildWhatsAppLink(item, useDueBalanceTemplate: true)"><span class="whatsapp-glyph" aria-hidden="true"></span>Due and Balance</a>
                                    </div>

                                    <div class="card-action-group danger-actions">
                                        <button type="button"
                                                class="delete-button"
                                                disabled="@(_isLoading || _transitioningOrderId == item.OrderId || _deletingOrderId == item.OrderId || _submittingPaymentOrderId == item.OrderId)"
                                                @onclick="() => PrepareDelete(item.OrderId)">
                                            @GetDeleteButtonText(item.OrderId)
                                        </button>
                                    </div>
                                </div>

                                @if (_pendingPaymentOrderId == item.OrderId)
                                {
                                    <div class="card-payment-panel" role="status">
                                        <p>
                                            Record a payment for <strong>@item.CustomerName</strong>.
                                            Current balance: <strong>@item.BalanceDue</strong>.
                                        </p>
                                        <div class="card-payment-grid">
                                            <label>
                                                Payment Amount
                                            <input type="number" min="0.01" max="@item.BalanceDue" step="0.01" @bind="_paymentAmountDraft" />
                                            </label>
                                            <label>
                                                Note (Optional)
                                                <input type="text" @bind="_paymentNoteDraft" placeholder="Cash, transfer, pickup" />
                                            </label>
                                        </div>
                                        <div class="card-payment-buttons">
                                            <button type="button"
                                                    class="card-payment-confirm-button"
                                                    disabled="@(_submittingPaymentOrderId == item.OrderId)"
                @onclick="() => SubmitPaymentAsync(item.OrderId, item.CustomerName, item.BalanceDue)">
                                                @GetSavePaymentText(item.OrderId)
                                            </button>
                                            <button type="button"
                                                    class="card-payment-cancel-button"
                                                    disabled="@(_submittingPaymentOrderId == item.OrderId)"
                                                    @onclick="CancelPayment">
                                                Cancel
                                            </button>
                                        </div>
                                    </div>
                                }

                                @if (_pendingDeleteOrderId == item.OrderId)
                                {
                                    <div class="card-delete-confirm" role="status">
                                        <p>
                                            Delete this order for <strong>@item.CustomerName</strong>?
                                            This removes it from the local store and syncs the delete upstream.
                                        </p>
                                        <div class="card-delete-confirm-buttons">
                                            <button type="button"
                                                    class="card-delete-confirm-button"
                                                    disabled="@(_deletingOrderId == item.OrderId)"
                                                    @onclick="() => ConfirmDeleteAsync(item.OrderId, item.CustomerName)">
                                                Confirm Delete
                                            </button>
                                            <button type="button"
                                                    class="card-delete-cancel-button"
                                                    disabled="@(_deletingOrderId == item.OrderId)"
                                                    @onclick="CancelDelete">
                                                Cancel
                                            </button>
                                        </div>
                                    </div>
                                }
                            </article>
                        }
                    </div>
                }
            </section>
        }
    }
</section>

@code {
    private const int DefaultMaxItems = 80;
    private const bool DefaultIncludeDelivered = false;
    private const bool DefaultOverdueOnly = false;
    private const string DefaultStatusFilter = OrdersBoardFilterStateMapper.AnyStatus;

    [Parameter]
    [SupplyParameterFromQuery(Name = "maxItems")]
    public int? MaxItemsQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "includeDelivered")]
    public bool? IncludeDeliveredQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "overdueOnly")]
    public bool? OverdueOnlyQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "dueOnOrBefore")]
    public string? DueOnOrBeforeQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "collapsedGroups")]
    public string? CollapsedGroupsQuery { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "preset")]
    public string? PresetQuery { get; set; }

    private string _apiBaseUrl = WorkspaceSettingsService.DefaultApiBaseUrl;
    private int _maxItems = DefaultMaxItems;
    private bool _includeDelivered = DefaultIncludeDelivered;
    private bool _overdueOnly = DefaultOverdueOnly;
    private string _statusFilter = DefaultStatusFilter;
    private DateTime? _dueOnOrBeforeDate;
    private bool _isLoading;
    private bool _hasLoaded;
    private DateTimeOffset _lastLoadedAtUtc;
    private string? _errorMessage;
    private string? _actionMessage;
    private bool _isActionSuccess;
    private Guid? _transitioningOrderId;
    private Guid? _pendingPaymentOrderId;
    private Guid? _submittingPaymentOrderId;
    private Guid? _pendingDeleteOrderId;
    private Guid? _deletingOrderId;
    private decimal? _paymentAmountDraft;
    private string? _paymentNoteDraft;
    private bool _isBulkAdvancing;
    private string? _lastAppliedFilterQueryKey;
    private string? _lastAppliedCollapsedGroupsQueryKey;
    private string? _lastAppliedPresetQueryKey;
    private OrdersBoardWorklistGroupKind? _bulkAdvancingGroupKind;
    private OrdersBoardBulkAdvancePlan? _pendingBulkAdvancePlan;
    private OrdersBoardWorklistGroupKind? _pendingRetryGroupKind;
    private OrdersBoardWorklistGroupKind? _openBulkActionsGroupKind;
    private readonly Dictionary<OrdersBoardWorklistGroupKind, GroupBulkAdvanceStatus> _groupBulkAdvanceStatuses = [];
    private readonly HashSet<OrdersBoardWorklistGroupKind> _expandedRetryableDetailKinds = [];
    private OrdersBoardSummary _summary = OrdersBoardSummaryBuilder.Empty;
    private OrdersBoardQuickPreset? _selectedPreset;
    private bool _useCompactOrderCards = true;
    private readonly OrdersBoardGroupUiState _groupUiState = new();
    private IReadOnlyList<OrdersBoardWorklistGroup> _groupedItems = [];
    private List<OrderWorklistItemDto> _items = [];

    protected override async Task OnParametersSetAsync()
    {
        var filterQueryKey = OrdersBoardFilterStateMapper.BuildQueryFingerprint(
            MaxItemsQuery,
            IncludeDeliveredQuery,
            OverdueOnlyQuery,
            StatusQuery,
            DueOnOrBeforeQuery);

        var collapsedGroupsQueryKey = OrdersBoardGroupUiState.BuildCollapsedGroupsQueryValue(
                OrdersBoardGroupUiState.ParseCollapsedGroupsQuery(CollapsedGroupsQuery))
            ?? string.Empty;

        var presetQueryKey = OrdersBoardFilterStateMapper.ToPresetQueryValue(
                OrdersBoardFilterStateMapper.ParsePreset(PresetQuery))
            ?? string.Empty;

        var filterChanged = !string.Equals(_lastAppliedFilterQueryKey, filterQueryKey, StringComparison.Ordinal);
        var collapsedGroupsChanged = !string.Equals(_lastAppliedCollapsedGroupsQueryKey, collapsedGroupsQueryKey, StringComparison.Ordinal);
        var presetChanged = !string.Equals(_lastAppliedPresetQueryKey, presetQueryKey, StringComparison.Ordinal);
        if (!filterChanged && !collapsedGroupsChanged && !presetChanged)
        {
            return;
        }

        _lastAppliedFilterQueryKey = filterQueryKey;
        _lastAppliedCollapsedGroupsQueryKey = collapsedGroupsQueryKey;
        _lastAppliedPresetQueryKey = presetQueryKey;

        var filters = OrdersBoardFilterStateMapper.FromQuery(
            WorkspaceSettings.ApiBaseUrl,
            DefaultMaxItems,
            DefaultIncludeDelivered,
            DefaultOverdueOnly,
            DefaultStatusFilter,
            MaxItemsQuery,
            IncludeDeliveredQuery,
            OverdueOnlyQuery,
            StatusQuery,
            DueOnOrBeforeQuery);

        ApplyFilters(filters);
        _groupUiState.SetCollapsedKinds(
            OrdersBoardGroupUiState.ParseCollapsedGroupsQuery(CollapsedGroupsQuery));
        var selectedPresetFromQuery = OrdersBoardFilterStateMapper.ParsePreset(PresetQuery);
        _selectedPreset = ResolveSelectedPreset(filters, selectedPresetFromQuery, DateTime.UtcNow);

        if (!_hasLoaded || _isLoading)
        {
            return;
        }

        if (filterChanged)
        {
            await LoadAsync();
            return;
        }

        if (presetChanged)
        {
            SyncStateToUrl(filters);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _apiBaseUrl = WorkspaceSettings.ApiBaseUrl;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _pendingBulkAdvancePlan = null;
        _pendingRetryGroupKind = null;
        _pendingDeleteOrderId = null;
        _errorMessage = null;

        try
        {
            var filters = BuildCurrentFilters();

            _selectedPreset = ResolveSelectedPreset(filters, _selectedPreset, DateTime.UtcNow);

            ApplyFilters(filters);

            SyncStateToUrl(filters);

            var normalizedStatus = string.Equals(filters.StatusFilter, OrdersBoardFilterStateMapper.AnyStatus, StringComparison.OrdinalIgnoreCase)
                ? null
                : filters.StatusFilter;

            var dueOnOrBeforeUtc = OrdersBoardFilterStateMapper.ToDueOnOrBeforeUtc(filters.DueOnOrBeforeDate);

            var result = await WorklistService.GetAsync(
                filters.ApiBaseUrl,
                filters.IncludeDelivered,
                filters.MaxItems,
                normalizedStatus,
                filters.OverdueOnly,
                dueOnOrBeforeUtc);

            _hasLoaded = true;
            _lastLoadedAtUtc = DateTimeOffset.UtcNow;

            if (!result.IsSuccess)
            {
                _items = [];
                _groupedItems = [];
                _groupUiState.SyncToGroups(_groupedItems);
                _summary = OrdersBoardSummaryBuilder.Empty;
                _expandedRetryableDetailKinds.Clear();
                _errorMessage = result.ErrorMessage ?? "Unable to load orders.";

                SyncStateToUrl(filters);
                return;
            }

            _items = ApplyClientPresetFilter(result.Items)
                .OrderBy(item => item.DueAtUtc)
                .ThenBy(item => item.CustomerName)
                .ToList();

            _groupedItems = OrdersBoardWorklistOrganizer.BuildGroups(_items, DateTime.UtcNow);
            _groupUiState.SyncToGroups(_groupedItems);
            PruneGroupBulkAdvanceStatuses(_groupedItems);
            PruneExpandedRetryableDetailKinds(_groupedItems);
            _summary = OrdersBoardSummaryBuilder.Build(_items, DateTime.UtcNow);

            SyncStateToUrl(filters);
        }
        finally
        {
            _isLoading = false;
        }
    }

