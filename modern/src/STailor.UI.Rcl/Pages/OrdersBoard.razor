        if (dueDate == todayUtc)
        {
            return "today";
        }

        return "upcoming";
    }

    private void PruneGroupBulkAdvanceStatuses(IReadOnlyList<OrdersBoardWorklistGroup> groups)
    {
        var activeKinds = groups
            .Select(group => group.Kind)
            .ToHashSet();

        var staleKinds = _groupBulkAdvanceStatuses.Keys
            .Where(kind => !activeKinds.Contains(kind))
            .ToList();

        foreach (var staleKind in staleKinds)
        {
            _groupBulkAdvanceStatuses.Remove(staleKind);
        }
    }

    private void PruneExpandedRetryableDetailKinds(IReadOnlyList<OrdersBoardWorklistGroup> groups)
    {
        var activeKinds = groups
            .Select(group => group.Kind)
            .ToHashSet();

        _expandedRetryableDetailKinds.RemoveWhere(kind =>
        {
            if (!activeKinds.Contains(kind))
            {
                return true;
            }

            if (!_groupBulkAdvanceStatuses.TryGetValue(kind, out var status))
            {
                return true;
            }

            var retryableNowCount = BuildSafeRetryCandidates(status).Count;
            return retryableNowCount <= 3;
        });
    }

