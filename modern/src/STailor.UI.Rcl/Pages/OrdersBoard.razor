        {
            _isActionSuccess = false;
            _actionMessage = $"No eligible orders to advance in {plan.GroupTitle}.";
            return;
        }

        _pendingRetryGroupKind = null;
        _pendingBulkAdvancePlan = plan;
        _openBulkActionsGroupKind = null;
        _actionMessage = null;
    }

    private void CancelGroupBulkAdvance()
    {
        _pendingBulkAdvancePlan = null;
    }

    private void PrepareGroupRetry(OrdersBoardWorklistGroupKind kind)
    {
        if (_isBulkAdvancing)
        {
            return;
        }

        if (!_groupBulkAdvanceStatuses.TryGetValue(kind, out var groupStatus))
        {
            _isActionSuccess = false;
            _actionMessage = "No previous failed orders were recorded for this group.";
            return;
        }

        var retryCandidates = BuildSafeRetryCandidates(groupStatus);
        if (retryCandidates.Count == 0)
        {
            _pendingRetryGroupKind = null;
            _isActionSuccess = false;
            _actionMessage = $"No safe failed orders to retry in {groupStatus.GroupTitle}.";
            return;
        }

        _pendingBulkAdvancePlan = null;
        _pendingRetryGroupKind = kind;
        _openBulkActionsGroupKind = null;
        _actionMessage = null;
    }

    private void CancelGroupRetry()
    {
        _pendingRetryGroupKind = null;
    }

    private async Task ConfirmGroupRetryAsync()
    {
        if (_pendingRetryGroupKind is null || _isBulkAdvancing)
        {
            return;
        }

        var kind = _pendingRetryGroupKind.Value;
        _pendingRetryGroupKind = null;

        await RetryGroupFailedAsync(kind);
    }

    private async Task ConfirmGroupBulkAdvanceAsync()
    {
        if (_pendingBulkAdvancePlan is null || _isBulkAdvancing)
        {
            return;
        }

        var plan = _pendingBulkAdvancePlan;
        _pendingBulkAdvancePlan = null;

        _isBulkAdvancing = true;
        _bulkAdvancingGroupKind = plan.GroupKind;
        _actionMessage = null;

        try
        {
            var successCount = 0;
            var failedCandidates = new List<OrdersBoardBulkAdvanceRetryCandidate>();

            foreach (var candidate in plan.Candidates)
            {
                var result = await WorklistService.TransitionStatusAsync(_apiBaseUrl, candidate.OrderId, candidate.TargetStatus);
                if (result.IsSuccess)
                {
                    successCount++;
                    continue;
                }

                failedCandidates.Add(new OrdersBoardBulkAdvanceRetryCandidate(
                    candidate.OrderId,
                    candidate.CustomerName,
                    candidate.TargetStatus));
            }

            var summary = OrdersBoardBulkAdvanceResultBuilder.Build(
                plan.GroupTitle,
                successCount,
                failedCandidates.Count,
                failedCandidates.Count == 0 ? null : failedCandidates[0].CustomerName);

            var occurredAtUtc = DateTimeOffset.UtcNow;

            _groupBulkAdvanceStatuses[plan.GroupKind] = new GroupBulkAdvanceStatus(
                plan.GroupTitle,
                summary,
                occurredAtUtc,
                failedCandidates,
                LastFailedAtUtc: OrdersBoardBulkResultMetaBuilder.ResolveLastFailedAtUtc(
                    previousLastFailedAtUtc: null,
                    failedCount: failedCandidates.Count,
                    occurredAtUtc));

            _isActionSuccess = summary.Outcome == OrdersBoardBulkAdvanceOutcome.Success;
            _actionMessage = summary.Message;

            await LoadAsync();
        }
        finally
        {
            _isBulkAdvancing = false;
            _bulkAdvancingGroupKind = null;
        }
    }

    private async Task RetryGroupFailedAsync(OrdersBoardWorklistGroupKind kind)
    {
        if (_isBulkAdvancing)
        {
            return;
        }

        if (!_groupBulkAdvanceStatuses.TryGetValue(kind, out var groupStatus))
        {
            return;
        }

        var retryCandidates = BuildSafeRetryCandidates(groupStatus);
        if (retryCandidates.Count == 0)
        {
            _isActionSuccess = false;
            _actionMessage = $"No safe failed orders to retry in {groupStatus.GroupTitle}.";
            return;
        }

        _isBulkAdvancing = true;
        _bulkAdvancingGroupKind = kind;
        _pendingBulkAdvancePlan = null;
        _pendingRetryGroupKind = null;
        _actionMessage = null;

        try
        {
            var successCount = 0;
            var failedCandidates = new List<OrdersBoardBulkAdvanceRetryCandidate>();

            foreach (var retryCandidate in retryCandidates)
            {
                var result = await WorklistService.TransitionStatusAsync(
                    _apiBaseUrl,
                    retryCandidate.OrderId,
                    retryCandidate.TargetStatus);

                if (result.IsSuccess)
                {
                    successCount++;
                    continue;
                }

                failedCandidates.Add(retryCandidate);
            }

            var summary = OrdersBoardBulkAdvanceResultBuilder.Build(
                groupStatus.GroupTitle,
                successCount,
                failedCandidates.Count,
                failedCandidates.Count == 0 ? null : failedCandidates[0].CustomerName,
                OrdersBoardBulkActionType.Retry);

            var occurredAtUtc = DateTimeOffset.UtcNow;

            _groupBulkAdvanceStatuses[kind] = groupStatus with
            {
                Summary = summary,
                OccurredAtUtc = occurredAtUtc,
                FailedCandidates = failedCandidates,
                LastFailedAtUtc = OrdersBoardBulkResultMetaBuilder.ResolveLastFailedAtUtc(
                    groupStatus.LastFailedAtUtc,
                    failedCandidates.Count,
                    occurredAtUtc),
            };

            _isActionSuccess = summary.Outcome == OrdersBoardBulkAdvanceOutcome.Success;
            _actionMessage = summary.Message;

            await LoadAsync();
        }
        finally
        {
            _isBulkAdvancing = false;
            _bulkAdvancingGroupKind = null;
        }
    }

