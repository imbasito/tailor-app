        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        padding: 0.25rem;
        border: 1px solid #d8e0e8;
        border-radius: 8px;
        background: #f8fafc;
        width: fit-content;
    }

    .settings-tabs button {
        min-height: 2.15rem;
        padding: 0 0.85rem;
        border: 1px solid transparent;
