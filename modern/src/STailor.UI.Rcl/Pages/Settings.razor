@page "/settings"
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using STailor.UI.Rcl.Services
@inject WorkspaceSettingsService WorkspaceSettings
@inject IBackupRestoreService BackupRestoreService
@inject IBackupRestoreDialogService BackupRestoreDialogService

<section class="settings-shell">
    <header class="settings-header">
        <p class="eyebrow">Store Setup</p>
        <h1>Settings</h1>
        <p>Keep the shop name, logo, and tailoring defaults in one simple place so the rest of the app stays clean.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="@(_isError ? "settings-feedback error" : "settings-feedback")" role="status">@_message</div>
    }

    <nav class="settings-tabs" aria-label="Settings sections">
        <button type="button" class="@GetSettingsTabClass(SettingsTab.Admin)" @onclick="() => SetSettingsTab(SettingsTab.Admin)">Admin</button>
        <button type="button" class="@GetSettingsTabClass(SettingsTab.Defaults)" @onclick="() => SetSettingsTab(SettingsTab.Defaults)">Defaults</button>
        <button type="button" class="@GetSettingsTabClass(SettingsTab.Backup)" @onclick="() => SetSettingsTab(SettingsTab.Backup)">Backup</button>
    </nav>

    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <div class="settings-form">
            @if (_activeSettingsTab == SettingsTab.Admin)
            {
                <label>
                    Shop / Product Name
                    <input type="text" @bind="_model.ProductName" placeholder="SINYX Tailor Management" />
                </label>

                <label>
                    Shop Phone
                    <input type="tel" @bind="_model.ShopPhoneNumber" placeholder="+92 300 1234567" />
                </label>

                <label class="full-width">
                    Shop Address
                    <input type="text" @bind="_model.ShopAddress" placeholder="Shop address for invoices and printed reports" />
                </label>

                <label>
                    NTN
                    <input type="text" @bind="_model.NationalTaxNumber" placeholder="National Tax Number" />
                </label>

                <label>
                    STRN
                    <input type="text" @bind="_model.SalesTaxRegistrationNumber" placeholder="Sales Tax Registration Number" />
                </label>

                <label class="full-width">
                    Sidebar Logo
                    <div class="logo-picker">
                        @if (!string.IsNullOrWhiteSpace(_model.LogoDataUrl))
                        {
                            <img class="logo-preview" src="@_model.LogoDataUrl" alt="Current sidebar logo" />
                        }
                        else
                        {
                            <div class="logo-placeholder">No logo selected</div>
                        }

                        <div class="logo-actions">
                            <label class="upload-button">
                                <span>Choose Logo</span>
                                <InputFile accept="image/*" OnChange="OnLogoSelectedAsync" />
                            </label>
                            <button type="button" class="ghost" @onclick="ClearLogo">Remove Logo</button>
                        </div>
                    </div>
                </label>

                <div class="full-width admin-tools">
                    <div>
                        <h2>Migration Import</h2>
                        <p>Use this only when setting up a shop or importing old records.</p>
                    </div>
                    <a class="admin-link" href="/migration/import">Open Migration Import</a>
                </div>

                <div class="full-width admin-tools reset-tools">
                    <div>
                        <h2>Reset App Defaults</h2>
                        <p>Restores the shop name, logo, hidden connection settings, garment list, and measurement defaults.</p>
                    </div>
                    <div class="settings-actions compact">
                        @if (_isConfirmingReset)
                        {
                            <button type="button" class="danger-button" @onclick="ConfirmResetAsync">Confirm Restore</button>
                            <button type="button" class="ghost" @onclick="CancelReset">Cancel</button>
                        }
                        else
                        {
                            <button type="button" class="ghost" @onclick="ArmReset">Reset Defaults</button>
                        }
                    </div>
                </div>
            }

            @if (_activeSettingsTab == SettingsTab.Defaults)
            {
                <div class="full-width garment-settings">
                    <div class="garment-settings-head">
                        <div>
                            <h2>Measurement Defaults</h2>
                            <p>Manage reusable measurement rows for each garment type. These become the starting point when creating new orders.</p>
                        </div>
                    </div>

                    <div class="defaults-toolbar">
                        <label>
                            Garment
                            <select value="@_selectedDefaultsGarmentType" @onchange="OnDefaultsGarmentChanged">
                                @foreach (var garmentType in WorkspaceSettings.GarmentTypes)
                                {
                                    <option value="@garmentType">@garmentType</option>
                                }
                            </select>
                        </label>
                        <div class="defaults-actions">
                            <button type="button" @onclick="SaveMeasurementDefaults">Save Defaults</button>
                        </div>
                    </div>

                    <div class="defaults-list">
                        @foreach (var row in _measurementDefaults)
                        {
                            <div class="defaults-row">
                                <input
                                    type="text"
                                    value="@row.Name"
                                    @oninput="eventArgs => UpdateDefaultMeasurementName(row.Id, eventArgs.Value?.ToString())"
                                    placeholder="Chest, Sleeve, Length" />
                                <input
                                    type="number"
                                    min="0.01"
                                    step="0.01"
                                    value="@row.Value"
                                    @oninput="eventArgs => UpdateDefaultMeasurementValue(row.Id, eventArgs.Value?.ToString())"
                                    placeholder="40" />
                                <button
                                    type="button"
                                    class="ghost danger-text"
                                    disabled="@(_measurementDefaults.Count == 1)"
                                    @onclick="() => RemoveDefaultMeasurementRow(row.Id)">
                                    Remove
                                </button>
                            </div>
                        }
                        <button type="button" class="add-row-button" title="Add measurement" aria-label="Add measurement" @onclick="AddDefaultMeasurementRow">+</button>
                    </div>
                </div>
            }

            @if (_activeSettingsTab == SettingsTab.Backup)
            {
                <div class="full-width backup-tools">
                    <div>
                        <h2>Backup & Restore</h2>
                        <p>Create a local safety copy before moving devices, testing large imports, or restoring client machines.</p>
                    </div>
                    <dl>
                        <div>
                            <dt>Backup Folder</dt>
                            <dd>@_backupFolderPath</dd>
                        </div>
                    </dl>
                    <label class="backup-folder-field">
                        Backup folder path
                        <input
                            type="text"
                            value="@_backupFolderPath"
                            @oninput="eventArgs => _backupFolderPath = eventArgs.Value?.ToString() ?? string.Empty"
                            placeholder="C:\Backups\SINYX" />
                    </label>
                    <div class="settings-actions compact">
                        <button type="button" class="ghost" disabled="@_isBackingUp || _isRestoring" @onclick="BrowseBackupFolderAsync" @onclick:preventDefault="true">Browse Folder</button>
                        <button type="button" disabled="@_isBackingUp || _isRestoring" @onclick="CreateBackupAsync" @onclick:preventDefault="true">
                            @(_isBackingUp ? "Creating..." : "Create Backup")
                        </button>
                        @if (_isConfirmingRestore)
                        {
                            <span class="selected-restore-file">@Path.GetFileName(_pendingRestoreManifestPath)</span>
                            <button type="button" class="danger-button" disabled="@_isRestoring" @onclick="ConfirmRestoreBackupAsync" @onclick:preventDefault="true">
                                @(_isRestoring ? "Restoring..." : "Confirm Restore")
                            </button>
                            <button type="button" class="ghost" disabled="@_isRestoring" @onclick="CancelRestoreBackup" @onclick:preventDefault="true">Cancel</button>
                        }
                        else
                        {
                            <button type="button" class="ghost" disabled="@_isBackingUp || _isRestoring" @onclick="ChooseRestoreBackupAsync" @onclick:preventDefault="true">Choose Restore File</button>
                        }
                    </div>
                    <p class="field-hint">Restore expects a selected <strong>backup-manifest.json</strong> file from a backup folder. It overwrites local settings and local database files after confirmation.</p>
                </div>
            }
        </div>

        @if (_activeSettingsTab == SettingsTab.Admin)
        {
            <div class="settings-actions">
                <button type="submit">Save Settings</button>
            </div>
        }
    </EditForm>
</section>

@code {
    private readonly SettingsViewModel _model = new();
    private string? _message;
    private bool _isError;
    private bool _isConfirmingReset;
    private bool _isBackingUp;
    private bool _isRestoring;
    private bool _isConfirmingRestore;
    private string _backupFolderPath = string.Empty;
    private string? _pendingRestoreManifestPath;
    private SettingsTab _activeSettingsTab = SettingsTab.Admin;

    protected override void OnInitialized()
    {
        _backupFolderPath = BackupRestoreService.BackupRootPath;
        HydrateFromService();
    }

    private Task SaveAsync()
    {
        try
        {
            WorkspaceSettings.UpdateBranding(_model.ProductName);
            WorkspaceSettings.UpdateLogo(_model.LogoDataUrl);
            WorkspaceSettings.UpdateShopProfile(
                _model.ShopAddress,
                _model.ShopPhoneNumber,
                _model.NationalTaxNumber,
                _model.SalesTaxRegistrationNumber);
            WorkspaceSettings.UpdateConnection(_model.ApiBaseUrl);
            HydrateFromService();
            _message = "Saved. The updated branding and defaults are live.";
            _isError = false;
        }
        catch (ArgumentException exception)
        {
            _message = exception.Message;
            _isError = true;
        }

        return Task.CompletedTask;
    }

    private void SetSettingsTab(SettingsTab tab)
    {
        _activeSettingsTab = tab;
        _isConfirmingReset = false;
        _isConfirmingRestore = false;
        _pendingRestoreManifestPath = null;
        _message = null;
        _isError = false;
    }

    private string GetSettingsTabClass(SettingsTab tab)
    {
        return _activeSettingsTab == tab ? "active" : string.Empty;
    }

    private async Task OnLogoSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 3 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var contentType = string.IsNullOrWhiteSpace(file.ContentType)
                ? "image/png"
                : file.ContentType;

            _model.LogoDataUrl = $"data:{contentType};base64,{Convert.ToBase64String(memoryStream.ToArray())}";
            _message = "Logo selected. Save to apply it.";
            _isError = false;
        }
        catch (IOException)
        {
            _message = "Selected logo is too large. Choose an image under 3 MB.";
            _isError = true;
        }
    }

    private void ClearLogo()
    {
        _model.LogoDataUrl = null;
        _message = "Logo cleared. Save to remove it from the sidebar.";
        _isError = false;
    }

    private void OnDefaultsGarmentChanged(ChangeEventArgs args)
    {
        _selectedDefaultsGarmentType = args.Value?.ToString() ?? WorkspaceSettings.GarmentTypes[0];
        HydrateMeasurementDefaults();
    }

    private void AddDefaultMeasurementRow()
    {
        _measurementDefaults.Add(new MeasurementDefaultRow(string.Empty, null));
    }

    private void RemoveDefaultMeasurementRow(Guid id)
    {
        _measurementDefaults.RemoveAll(row => row.Id == id);
        if (_measurementDefaults.Count == 0)
        {
            _measurementDefaults.Add(new MeasurementDefaultRow(string.Empty, null));
        }
    }

    private void UpdateDefaultMeasurementName(Guid id, string? value)
    {
        var row = _measurementDefaults.FirstOrDefault(item => item.Id == id);
        if (row is not null)
        {
            row.Name = value ?? string.Empty;
        }
    }

    private void UpdateDefaultMeasurementValue(Guid id, string? value)
    {
        var row = _measurementDefaults.FirstOrDefault(item => item.Id == id);
        if (row is not null)
        {
            row.Value = decimal.TryParse(value, out var parsedValue) ? parsedValue : null;
        }
    }

    private void SaveMeasurementDefaults()
    {
        var defaults = _measurementDefaults
            .Where(row => !string.IsNullOrWhiteSpace(row.Name) && row.Value is > 0m)
            .Select(row => new GarmentMeasurementDefault(row.Name.Trim(), row.Value!.Value))
            .ToArray();

        if (defaults.Length == 0)
        {
            _message = "Add at least one valid measurement default.";
            _isError = true;
            return;
        }

        WorkspaceSettings.UpdateMeasurementDefaults(_selectedDefaultsGarmentType, defaults);
        HydrateMeasurementDefaults();
        _message = $"Defaults saved for {_selectedDefaultsGarmentType}.";
        _isError = false;
    }

    private void ArmReset()
    {
        _isConfirmingReset = true;
        _message = "Confirm restore to reset branding, logo, connection, and measurement defaults.";
        _isError = false;
    }

    private void CancelReset()
    {
        _isConfirmingReset = false;
        _message = null;
        _isError = false;
    }

    private Task ConfirmResetAsync()
    {
        WorkspaceSettings.ResetToDefaults();
        HydrateFromService();
        _isConfirmingReset = false;
        _message = "Defaults restored.";
        _isError = false;
        return Task.CompletedTask;
    }

    private async Task CreateBackupAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_backupFolderPath))
            {
                _message = "Choose or type a backup folder first.";
                _isError = true;
                return;
            }

            _isBackingUp = true;
            _message = "Creating backup...";
            _isError = false;
            var result = await BackupRestoreService.CreateBackupAsync(_backupFolderPath);

            _message = result.BackupPath is null
                ? result.Message
                : $"{result.Message} Folder: {result.BackupPath}";
            _isError = !result.IsSuccess;
        }
        catch (Exception exception)
        {
            _message = $"Backup failed: {exception.Message}";
            _isError = true;
        }
        finally
        {
            _isBackingUp = false;
        }
    }

    private async Task BrowseBackupFolderAsync()
    {
        try
        {
            _message = "Opening folder picker...";
            _isError = false;
            var selectedPath = await BackupRestoreDialogService.PickBackupFolderAsync(_backupFolderPath);
            if (string.IsNullOrWhiteSpace(selectedPath))
            {
                _message = "No folder selected. You can type a folder path manually.";
                _isError = false;
                return;
            }

            _backupFolderPath = selectedPath;
            _message = "Backup folder selected.";
            _isError = false;
        }
        catch (Exception exception)
        {
            _message = $"Folder picker failed. Type the folder path manually. Details: {exception.Message}";
            _isError = true;
        }
    }

    private async Task ChooseRestoreBackupAsync()
    {
        try
        {
            _message = "Opening restore file picker...";
            _isError = false;
            var selectedPath = await BackupRestoreDialogService.PickRestoreManifestAsync(_backupFolderPath);
            if (string.IsNullOrWhiteSpace(selectedPath))
            {
                _message = "No restore file selected.";
                _isError = false;
                return;
            }

            _pendingRestoreManifestPath = selectedPath;
            _isConfirmingRestore = true;
            _message = "Confirm restore only if you want to replace the current local settings/data with the selected backup.";
            _isError = false;
        }
        catch (Exception exception)
        {
            _message = $"Restore file picker failed: {exception.Message}";
            _isError = true;
        }
    }

    private void CancelRestoreBackup()
    {
        _isConfirmingRestore = false;
        _pendingRestoreManifestPath = null;
        _message = null;
        _isError = false;
    }

    private async Task ConfirmRestoreBackupAsync()
    {
        if (string.IsNullOrWhiteSpace(_pendingRestoreManifestPath))
        {
            _message = "Choose a restore file before confirming.";
            _isError = true;
            return;
        }

        try
        {
            _isRestoring = true;
            _message = "Restoring backup...";
            _isError = false;
            var result = await BackupRestoreService.RestoreBackupAsync(_pendingRestoreManifestPath);

            if (result.IsSuccess)
            {
                HydrateFromService();
            }

            _message = result.BackupPath is null
                ? result.Message
                : $"{result.Message} Source: {result.BackupPath}";
            _isError = !result.IsSuccess;
        }
        catch (Exception exception)
        {
            _message = $"Restore failed: {exception.Message}";
            _isError = true;
        }
        finally
        {
            _isRestoring = false;
            _isConfirmingRestore = false;
            _pendingRestoreManifestPath = null;
        }
    }

    private void HydrateFromService()
    {
        _model.ProductName = WorkspaceSettings.ProductName;
        _model.ApiBaseUrl = WorkspaceSettings.ApiBaseUrl;
        _model.LogoDataUrl = WorkspaceSettings.LogoDataUrl;
        _model.ShopAddress = WorkspaceSettings.ShopAddress;
        _model.ShopPhoneNumber = WorkspaceSettings.ShopPhoneNumber;
        _model.NationalTaxNumber = WorkspaceSettings.NationalTaxNumber;
        _model.SalesTaxRegistrationNumber = WorkspaceSettings.SalesTaxRegistrationNumber;
        if (!WorkspaceSettings.GarmentTypes.Contains(_selectedDefaultsGarmentType, StringComparer.OrdinalIgnoreCase))
        {
            _selectedDefaultsGarmentType = WorkspaceSettings.GarmentTypes[0];
        }

        HydrateMeasurementDefaults();
    }

    private void HydrateMeasurementDefaults()
    {
        _measurementDefaults.Clear();
        _measurementDefaults.AddRange(WorkspaceSettings
            .GetMeasurementDefaults(_selectedDefaultsGarmentType)
            .Select(row => new MeasurementDefaultRow(row.Name, row.Value)));
    }

    private sealed class SettingsViewModel
    {
        public string ProductName { get; set; } = string.Empty;

        public string ApiBaseUrl { get; set; } = string.Empty;

        public string? LogoDataUrl { get; set; }

        public string ShopAddress { get; set; } = string.Empty;

        public string ShopPhoneNumber { get; set; } = string.Empty;

        public string NationalTaxNumber { get; set; } = string.Empty;

        public string SalesTaxRegistrationNumber { get; set; } = string.Empty;

    }

    private string _selectedDefaultsGarmentType = WorkspaceSettingsService.DefaultGarmentTypes[0];

    private readonly List<MeasurementDefaultRow> _measurementDefaults = [];

    private sealed class MeasurementDefaultRow
    {
        public MeasurementDefaultRow(string name, decimal? value)
        {
            Name = name;
            Value = value;
        }

        public Guid Id { get; } = Guid.NewGuid();

        public string Name { get; set; }

        public decimal? Value { get; set; }
    }

    private enum SettingsTab
    {
        Admin,
        Defaults,
        Backup,
    }
}

<style>
