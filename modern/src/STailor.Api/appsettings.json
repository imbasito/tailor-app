{
  "ConnectionStrings": {
    "Local": "Data Source=stailor-local.db",
    "Central": "Host=localhost;Port=5432;Database=stailor;Username=postgres;Password=postgres"
  },
  "SyncWorker": {
    "Enabled": false,
    "DryRun": true,
    "PollIntervalSeconds": 30,
    "MaxBatchSize": 25
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
